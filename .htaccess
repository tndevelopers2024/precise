<IfModule pagespeed_module>
    ModPagespeed off
</IfModule>

<IfModule LiteSpeed>
    CacheDisable public /
    CacheDisable private /
</IfModule>

RewriteEngine On

# Skip redirect for localhost and local IPs
RewriteCond %{HTTP_HOST} ^(localhost|127\.0\.0\.1)$ [NC]
RewriteRule ^ - [L]

# Apply redirect ONLY for precise3dm.com
RewriteCond %{HTTP_HOST} ^(www\.)?precise3dm\.com$ [NC]
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\.precise3dm\.com$ [NC]
RewriteRule ^(.*)$ https://www.precise3dm.com/$1 [R=301,L]


